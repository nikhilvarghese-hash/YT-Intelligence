# ── YouTube ───────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# ── AI Provider ───────────────────────────────────────────────────────────────
# Set AI_PROVIDER to one of: none | openai | anthropic | gemini | ollama | openrouter
# Leave all unused provider keys blank.

AI_PROVIDER=none
AI_MODEL=

OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama runs locally — no key needed, just set the base URL
OLLAMA_BASE_URL=http://localhost:11434

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./youtube_intelligence.db

# ── Server ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
